# =============================================================================
# VM Inventory Manager — Linux Docker deployment
# Setup:  cp .env.example .env  &&  nano .env
# Deploy: docker compose up -d --build
# =============================================================================

# --- PostgreSQL data directory (bind mount on host) ---
# Database files are stored under ./data/ in the project folder
POSTGRES_DATA_DIR=./data

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vm_inventory
POSTGRES_PORT=5432

# --- Web application ---
APP_PORT=3000

# Public URL (REQUIRED — use your Linux server IP or domain)
# Example: http://192.168.1.50:3000  or  https://vms.company.com
NEXTAUTH_URL=http://localhost:3000

# Session secret (REQUIRED — min 32 characters, change in production)
NEXTAUTH_SECRET=change-me-generate-a-random-32-char-secret

# --- First-deploy admin account (no dummy data is created) ---
ADMIN_USERNAME=zamir.amiri
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_NAME=Zamir Amiri
# ADMIN_EMAIL=zamir.amiri@ahg.local
# ADMIN_DEPARTMENT=IT Infrastructure
# Set false to skip admin bootstrap on init-db (only if users already exist)
BOOTSTRAP_ADMIN=true

# --- Optional tools profile ---
STUDIO_PORT=5555

# --- Internal Docker network (do not change host "postgres") ---
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/vm_inventory?schema=public
