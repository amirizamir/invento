# =============================================================================
# AHG — Linux Docker deployment
# Setup:  cp .env.example .env  &&  nano .env
# Deploy: docker compose up -d --build
# =============================================================================

# --- PostgreSQL data directory (bind mount on host) ---
POSTGRES_DATA_DIR=./data

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vm_inventory
POSTGRES_PORT=5432

# --- Web application ---
APP_PORT=3000

# Public URL (REQUIRED — use your Linux server IP or domain)
NEXTAUTH_URL=http://localhost:3000

# Session secret (REQUIRED — min 32 characters)
NEXTAUTH_SECRET=change-me-generate-a-random-32-char-secret

# --- First-deploy admin account (REQUIRED on first deploy) ---
# Use quotes if the password contains special characters (!, %, *, etc.)
ADMIN_USERNAME=zamir.amiri
ADMIN_PASSWORD="change-me-strong-admin-password"
ADMIN_NAME=Zamir Amiri
BOOTSTRAP_ADMIN=true

# --- Optional tools profile ---
STUDIO_PORT=5555

# DATABASE_URL is built automatically inside Docker from POSTGRES_* variables above.
