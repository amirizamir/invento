generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

enum VMStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
  MAINTENANCE
  PENDING
}

enum Platform {
  VMWARE
  HYPERV
  AWS
  AZURE
  GCP
  PROXMOX
  OPENSTACK
  OTHER
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Environment {
  DEV
  TEST
  QA
  STAGING
  PRODUCTION
}

enum PowerState {
  ON
  OFF
  SUSPENDED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  EOL_WARNING
  BACKUP_MISSING
  MONITORING_MISSING
  IMPORT_FAILED
  SYSTEM_ALERT
  VM_CREATED
  VM_UPDATED
  HARDWARE_CREATED
  HARDWARE_UPDATED
}

enum HardwareCategory {
  SERVER
  SWITCH
  ROUTER
  FIREWALL
  HSM
  NAS
  STORAGE
  UPS
  OTHER
}

enum HardwareManufacturer {
  DELL
  CISCO
  SYNOLOGY
  HPE
  HP
  JUNIPER
  FORTINET
  PALO_ALTO
  THALES
  IBM
  LENOVO
  SUPERMICRO
  APC
  NETAPP
  OTHER
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(VIEWER)
  department    String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  notifications Notification[]
  importJobs    ImportJob[]

  @@index([email])
  @@index([role])
}

model VirtualMachine {
  id                        String       @id @default(cuid())
  vmId                      String?
  hostname                  String
  vmName                    String
  description               String?
  environment               Environment  @default(DEV)
  platform                  Platform     @default(OTHER)
  useCase                   String?
  ipAddress                 String?
  secondaryIp               String?
  tertiaryIp                String?
  sshPort                   Int?
  rdpPort                   Int?
  remoteAccessMethod        String?
  dnsRecords                String?
  vlan                      String?
  firewallZone              String?
  osType                    String?
  osVersion                 String?
  kernelVersion             String?
  installedServices         String?
  cpuCores                  Int          @default(1)
  memoryGB                  Int          @default(4)
  storageGB                 Int          @default(50)
  physicalHost              String?
  datacenter                String?
  diskType                  String?
  storageDatastore          String?
  haEnabled                 Boolean      @default(false)
  cluster                   String?
  backupPolicy              String?
  backupType                String?
  patchLevel                String?
  antivirusInstalled        Boolean      @default(false)
  lastVulnerabilityScanDate  DateTime?
  cisStigHardening          Boolean      @default(false)
  encryptionAtRest          Boolean      @default(false)
  complianceTags            String[]     @default([])
  owner                     String?
  department                String?
  businessUnit              String?
  application               String?
  criticality               Criticality  @default(MEDIUM)
  status                    VMStatus     @default(PENDING)
  powerState                PowerState   @default(OFF)
  backupEnabled             Boolean      @default(false)
  monitoringEnabled         Boolean      @default(false)
  patchGroup                String?
  location                  String?
  resourcePool              String?
  costCenter                String?
  tags                      String[]     @default([])
  notes                     String?
  createdBy                 String?
  createdDate               DateTime     @default(now())
  updatedDate               DateTime     @updatedAt
  lastPatchDate             DateTime?
  endOfLifeDate             DateTime?

  @@index([hostname])
  @@index([vmName])
  @@index([vmId])
  @@index([platform])
  @@index([environment])
  @@index([status])
  @@index([criticality])
  @@index([department])
  @@index([owner])
  @@index([application])
  @@index([physicalHost])
}

model HardwareEquipment {
  id                  String               @id @default(cuid())
  assetId             String?
  name                String
  description         String?
  category            HardwareCategory     @default(OTHER)
  manufacturer        HardwareManufacturer @default(OTHER)
  model               String?
  serialNumber        String?
  partNumber          String?
  status              VMStatus             @default(PENDING)
  criticality         Criticality          @default(MEDIUM)
  environment         Environment          @default(PRODUCTION)
  datacenter          String?
  site                String?
  room                String?
  rack                String?
  rackUnit            String?
  location            String?
  hostname            String?
  managementIp        String?
  macAddress          String?
  vlan                String?
  subnet              String?
  cpuModel            String?
  cpuCores            Int?
  ramGB               Int?
  storageGB           Int?
  storageType         String?
  portCount           Int?
  firmwareVersion     String?
  biosVersion         String?
  osVersion           String?
  formFactor          String?
  powerSupplyWatts    Int?
  purchaseDate        DateTime?
  warrantyExpiry      DateTime?
  supportContractEnd  DateTime?
  vendor              String?
  poNumber            String?
  endOfLifeDate       DateTime?
  lastMaintenanceDate DateTime?
  owner               String?
  department          String?
  businessUnit        String?
  costCenter          String?
  monitoringEnabled   Boolean              @default(false)
  encryptionCapable   Boolean              @default(false)
  complianceTags      String[]             @default([])
  tags                String[]             @default([])
  notes               String?
  createdBy           String?
  createdDate         DateTime             @default(now())
  updatedDate         DateTime             @updatedAt

  @@index([assetId])
  @@index([name])
  @@index([category])
  @@index([manufacturer])
  @@index([serialNumber])
  @@index([status])
  @@index([criticality])
  @@index([department])
  @@index([owner])
  @@index([managementIp])
  @@index([hostname])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  timestamp  DateTime @default(now())
  oldValue   Json?
  newValue   Json?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([timestamp])
}

model ImportJob {
  id                String       @id @default(cuid())
  fileName          String
  status            ImportStatus @default(PENDING)
  totalRecords      Int          @default(0)
  successfulRecords Int          @default(0)
  failedRecords     Int          @default(0)
  errors            Json?
  startedAt         DateTime     @default(now())
  completedAt       DateTime?
  userId            String?
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  description String
  read        Boolean          @default(false)
  userId      String
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model SavedView {
  id        String   @id @default(cuid())
  name      String
  userId    String
  filters   Json
  columns   Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VMDraft {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
